{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/pedidos/[id]",
      "regex": "^/admin/pedidos/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/pedidos/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/pedidos/[id]/download",
      "regex": "^/api/admin/pedidos/([^/]+?)/download(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/pedidos/(?<nxtPid>[^/]+?)/download(?:/)?$"
    },
    {
      "page": "/api/admin/pedidos/[id]/status",
