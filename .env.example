# ═══════════════════════════════════════════
# DESENVOLVIMENTO LOCAL (SQLite)
# ═══════════════════════════════════════════
DATABASE_URL="file:./dev.db"

# ═══════════════════════════════════════════
# PRODUÇÃO (Render - PostgreSQL)
# O Render fornece DATABASE_URL automaticamente
# ═══════════════════════════════════════════
# DATABASE_URL="postgresql://..."  ← Render auto-provides this

# NextAuth (obrigatório)
AUTH_SECRET="generate-a-random-64-char-string"
# Em produção no Render: https://seuapp.onrender.com
AUTH_URL="http://localhost:3000"

# Stripe (opcional - pagamentos online)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (opcional - emails transacionais)
RESEND_API_KEY="re_..."

# Upload de imagens
UPLOAD_PROVIDER="local"
